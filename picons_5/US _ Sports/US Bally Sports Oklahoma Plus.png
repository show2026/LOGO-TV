ayerHighlight1\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/CMy6jQdynUAk0xQjpN3TL/7f675aca653d680d4dce1064abaaaca6/MayerHighlight1.png\",\"details\":{\"size\":296982,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"MayerHighlight1.png\",\"contentType\":\"image/png\"}}},{\"type\":\"fighterHighlight\",\"id\":\"10CWRu5UxOlhzmQ9AyjNo5\",\"title\":\"Natasha Jonas L10\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Fails in her bid to take her opponent’s welterweight title, losing a razor-thin decision some believe should’ve gone her way.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"7sQV5wELWsh8hrKo3NaPHL\",\"title\":\"MayerHighlight2\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/7sQV5wELWsh8hrKo3NaPHL/9c3c4e471857ddfc5e6e8f9403541f43/MayerHighlight2.png\",\"details\":{\"size\":193696,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"MayerHighlight2.png\",\"contentType\":\"image/png\"}}},{\"type\":\"fighterHighlight\",\"id\":\"48guSUMVzCkuIeIvGwrpeq\",\"title\":\"Alycia Baumgardner L10\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Ends up on the wrong side of a disputed decision but performs well in a thrilling title-unification bout on a big stage.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"3jJjw7pEgokJXx2sMXirIe\",\"title\":\"MayerHighlight3\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/3jJjw7pEgokJXx2sMXirIe/5893253c69d359bc5b2a0136c6b4a766/MayerHighlight3.png\",\"details\":{\"size\":209597,\"image\":{\"width\":1024,\"height\":605}},\"fileName\":\"MayerHighlight3.png\",\"contentType\":\"image/png\"}}},{\"type\":\"fighterHighlight\",\"id\":\"3t08RM39izMHNlzsDPJjsS\",\"title\":\"  Maiva Hama