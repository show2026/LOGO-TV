on\":\"$2:props:children:1:props:children:props:children:props:children:props:children:1:props:children:props:data:header:items:1:referencedRankings:0:rankFighters:0:fights:0:fighterB:fights:1:division:organization\",\"gender\":\"$2:props:children:1:props:children:props:children:props:children:props:children:1:props:children:props:data:header:items:1:referencedRankings:0:rankFighters:0:fights:0:fighterB:fights:1:division:gender\",\"weightClass\":\"$2:props:children:1:props:children:props:children:props:children:props:children:1:props:children:props:data:header:items:1:referencedRankings:0:rankFighters:0:fights:0:fighterB:fights:1:division:weightClass\"},\"isTitleFight\":false,\"titlesOnTheLine\":[{\"type\":\"Link\",\"id\":\"4zPbNChQNcHQJV6t50YVU1\"}],\"startTime\":\"2026-06-14T01:30+00:00\",\"endTime\":\"2026-06-14T04:00+00:00\",\"location\":{\"type\":\"venue\",\"id\":\"7qweBz2TEqTg1lJuFS2uwS\",\"venueName\":\"Desert Diamond Arena\",\"address\":\"$2:props:children:1:props:children:props:children:props:children:props:children:1:props:children:props:data:header:items:1:referencedRankings:0:rankFighters:3:fights:4:location:address\",\"city\":\"Glendale\",\"country\":\"US\"},\"noOfRounds\":12,\"includeInFantasy\":true}}]},{\"type\":\"accordion\",\"id\":\"2LHvn7TPhKsY6GIFg8wO0Y\",\"internalTitle\":\"Fanzone FAQ\",\"Items\":[{\"type\":\"accordionItem\",\"id\":\"1nStbGSLLNHlXEcb248yoi\",\"heading\":\"What is The Ring online community?\",\"body\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"The Ring online community is a place for boxing fans to connect, share opinions, and discuss fights, fighters, and news. It includes discussion boards and comment sections on articles, allowing members to join the conversation with other fans around the world.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"}},{\"type\":\"accordionItem\",\"id\":\"455q23dwvfoCAfREUjvRXh\",\"heading\":\"Do I need an account to join the community?\",\"body\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Yes. You must sign up for a free The Ring account to access the discussion boards and comment on news articles. Creating an account helps keep the community safe, respectful, and engaging for everyone.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"}},{\"type\":\"accordionItem\",\"id\":\"71YLSyjorcYXKJScxAswxz\",\"heading\":\"What can I post in the discussion boards and comments?\",\"body\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"You’re welcome to share your thoughts on boxing news, fights, rankings, and history. Posts should stay relevant to boxing and contribute constructively to the discussion. Off-topic, spam, or disruptive posts may be removed.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"}},{\"type\":\"accordionItem\",\"id\":\"4miOqhoxeGNalwM0gtY3AX\",\"heading\":\"What are the community rules?\",\"body\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Members are expected to be respectful and courteous at all times. Swearing, harassment, hate speech, or posting inappropriate or offensive content is not allowed. Breaking these rules may result in content removal, temporary suspension, or a permanent ban.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"}},{\"type\":\"accordionItem\",\"id\":\"15kCeAnhQWTEuqql7BHhIH\",\"heading\":\"What happens if someone breaks the rules?\",\"body\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"If a member violates the community guidelines, moderators may issue a warning, remove posts, or restrict access to the community. Repeated or serious violations can lead to a permanent ban to protect the experience for other members.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"n