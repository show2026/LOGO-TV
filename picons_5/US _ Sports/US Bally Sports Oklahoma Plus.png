\":\"“I always set a hot pace every time I go in there, I have a high work rate, but I can also adapt to any situation.\\\"\",\"citation\":\"Amanda Serrano\",\"isOnEventPage\":false},\"fighterHighlights\":[{\"type\":\"fighterHighlight\",\"id\":\"6ePYKqkzUNfQkJZ6csrpqT\",\"title\":\"Katie Taylor I L10\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Close setback in a thrilling fight between two of the biggest names in the sport kicked off a compelling trilogy in a four-year period.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"2lgjmCoXoJ03psGXJhpZW9\",\"title\":\"SerranoHighlight1\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/2lgjmCoXoJ03psGXJhpZW9/75ff9da8b22a091e88a4d23885930e2f/SerranoHighlight1.png\",\"details\":{\"size\":296078,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"SerranoHighlight1.png\",\"contentType\":\"image/png\"}}},{\"type\":\"fighterHighlight\",\"id\":\"WnXk9bufooPzs75huR5Sb\",\"title\":\"  Erika Cruz W10\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Outboxes her rival to win a unanimous decision and claim her fourth featherweight belt, making her the undisputed champion.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"4SGksHG6LdYyIbt54WiBR2\",\"title\":\"SerranoHighlight2\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/4SGksHG6LdYyIbt54WiBR2/700e30b6a3cfe609c5b3021d7fcfa45e/SerranoHighlight2.png\",\"details\":{\"size\":371140,\"image\":{\"width\":1024,\"height\":714}},\"fileName\":\"SerranoHighlight2.png\",\"contentType\":\"image/png\"}}},{\"type\":\"fighterHighlight\",\"id\":\"1imIqLXm5j7jhVxoZY5fvA\",\"title\":\"Eva Voraberger KO1\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Needs only 35 seconds to stop her opponent and win a major title in a seventh division (junior bantamweight), which is a record for women boxers.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"2ulLEQeLGMFxroMxOzq8xw\",\"title\":\"SerranoHighlight3\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/2ulLEQeLGMFxroMxOzq8xw/97bcec73f63dd12a6765a2e9c3ead1ac/SerranoHighlight3.png\",\"details\":{\"size\":304882,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"SerranoHighlight3.png\",\"contentType\":\"image/png\"}}},{\"type\":\"fighterHighlight\",\"id\":\"6nnT11XORBmLlKRDOQgtgW\",\"title\":\"Danila Ramos W12\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Shuts out her overmatched foe in the first women’s championship bout scheduled for 12, three- minute rounds, adding to her legacy as a trailblazer.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"3X0YNLKWtuxcEMGK3oTfeQ\",\"title\":\"SerranoHighlight4\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/3X0YNLKWtuxcEMGK3oTfeQ/00d029b791ebafb12e8ad46ca4680aed/SerranoHighlight4.png\",\"details\":{\"size\":327418,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"SerranoHighlight4.png\",\"contentType\":\"image/png\"}}}],\"ringSays\":[{\"type\":\"ringSays\",\"id\":\"19uDhvN0qKpZvoNsQFdyF7\",\"title\":\"Record pursuit\",\"isSmallVariant\":true,\"isLargeVariant\":false,\"largeVariationBodyCopy\":null,\"smallVariationBodyCopy\":\"She wants to surpass Christy Martin's 32 KOs for most all-time by a woman.\"},{\"type\":\"ringSays\",\"id\":\"4hSxcCLM0aHwuRDueRpl5c\",\"title\":\"Rare feat\",\"isSmallVariant\":true,\"isLargeVariant\":false,\"largeVariationBodyCopy\":null,\"smallVariationBodyCopy\":\"The third fight is a tiebreaker in a trilogy.