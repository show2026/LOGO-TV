id\":\"14101\",\"name\":\"OSCAR COLLAZO vs. REYNERIS GUITERREZ 01-28-2024\"}}],\"last5Bouts\":\"WWWWW\",\"debut\":\"2020-02-15T00:00:00.000Z\",\"wins\":13,\"losses\":0,\"draws\":0,\"kOs\":10,\"amateurDebut\":\"2015-12-05T00:00:00.000Z\",\"winsAmateur\":20,\"lossesAmateur\":9,\"drawsAmateur\":0,\"kOsAmateur\":1,\"quote\":{\"type\":\"blockquote\",\"id\":\"5UGssc2GDurSkzclubYvsa\",\"internalTitle\":\"Oscar Collazo quote\",\"quote\":\"I was willing to fight [other champions] and believe me, I want them, they are holding my titles.\",\"citation\":\"Oscar Collazo\",\"backgroundColour\":\"Blue\",\"isOnEventPage\":false},\"fighterHighlights\":[{\"type\":\"fighterHighlight\",\"id\":\"1VNe7vy8pHswbqjTZ45JNo\",\"title\":\"Jayson Vayson KO7\",\"bodyCopy\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Vayson rarely met someone he couldn’t stop. That is, until he ran into Collazo. In just seven incredibly lopsided rounds, Vayson was violently taken out of his misery.\",\"marks\":[],\"data\":{}}]}]},\"image\":{\"type\":\"Asset\",\"id\":\"1L3QskjPOWZzVf97vvydiB\",\"title\":\"CollazoHighlight1\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/1L3QskjPOWZzVf97vvydiB/f026da1c9db62a8986cd289d078d44f0/CollazoHighlight1.jpg\",\"details\":{\"size\":170680,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"CollazoHighlight1.jpg\",\"contentType\":\"image/jpeg\"}}},{\"type\":\"fighterHighlight\",\"id\":\"4bYZtDsvaNasulqfhHesNN\",\"title\":\"Thamanoon Niyomtrong TKO7\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Niyomtrong was undefeated and full of confidence. None of that mattered against Collazo. After winning every second of every round, Collazo eventually closed the show strong.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"gFJZk2VFijy3NG3UByx5D\",\"title\":\"CollazoHighlight2\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/gFJZk2VFijy3NG3UByx5D/8ec5165d0b6592294edcaf9bd37c1e9f/CollazoHighlight2.jpg\",\"details\":{\"size\":62922,\"image\":{\"width\":720,\"height\":479}},\"fileName\":\"CollazoHighlight2.jpg\",\"contentType\":\"image/jpeg\"}}},{\"type\":\"fighterHighlight\",\"id\":\"636rv2nYypSK9Jl0d8jDx5\",\"title\":\"Edwin Cano Hernandez KO5\",\"bodyCopy\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"One-way action is the best way to describe this matchup. A sneaky body shot sent Hernandez to the canvas to end it.\",\"marks\":[],\"data\":{}}]}]},\"image\":{\"type\":\"Asset\",\"id\":\"6VKMf7hWKAo02D1HxO4pLx\",\"title\":\"CollazoHighlight3\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/6VKMf7hWKAo02D1HxO4pLx/6b99ac8785894c18c52e906043229759/CollazoHighlight3.jpg\",\"details\":{\"size\":123137,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"CollazoHighlight3.jpg\",\"contentType\":\"image/jpeg\"}}},{\"type\":\"fighterHighlight\",\"id\":\"3mMJMErihsW2Pt2XsjhLzd\",\"title\":\"Melvin Jerusalem TKO7\",\"bodyCopy\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Jerusalem went undefeated in six years, but that didn’t stop Collazo from blasting him out.\",\"marks\":[],\"data\":{}}]}]},\"image\":{\"type\":\"Asset\",\"id\":\"4KV18haPHgUMGKX5gcYfRw\",\"title\":\"CollazoHighlight4\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/4KV18haPHgUMGKX5gcYfRw/64a71c3719fa5bb7a66975b88269b045/CollazoHighlight4.jpg\",\"details\":{\"size\":102771,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"CollazoHighlight4.jpg\",\"contentType\":\"image/jpeg\"}}}],\"ringSays\":[{\"type\":\"ringSays\",\"id\":\"7m9U8xvbQPBDXjsswtEVNM\",\"title\":\"All-out action\",\"isSmallVariant\":true,\"isLargeVariant\":false,\"la