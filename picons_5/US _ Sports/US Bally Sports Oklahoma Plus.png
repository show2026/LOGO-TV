yman.\",\"marks\":[],\"data\":{}}]}]},\"image\":{\"type\":\"Asset\",\"id\":\"LaLE7gaPCsa0dNytw9uj1\",\"title\":\"NavaretteHighlight1\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/LaLE7gaPCsa0dNytw9uj1/176a864653dcf0431fb8bb4d187ecdce/NavaretteHighlight1.jpg\",\"details\":{\"size\":55073,\"image\":{\"width\":768,\"height\":432}},\"fileName\":\"NavaretteHighlight1.jpg\",\"contentType\":\"image/jpeg\"}}},{\"type\":\"fighterHighlight\",\"id\":\"7jUyNlECu7xVmsw6Lvf3ob\",\"title\":\"Isaac Dogboe W12\",\"bodyCopy\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"In his U.S. debut, Navarrete pulled off the upset, winning a hard-fought unanimous decision to win his first world title and become the WBO super bantamweight champion.\",\"marks\":[],\"data\":{}}]}]},\"image\":{\"type\":\"Asset\",\"id\":\"186BJAt8lF0k79wSehuqEf\",\"title\":\"NavaretteHighlight2\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/186BJAt8lF0k79wSehuqEf/465b284319bab913708f8e99ff31a66e/NavaretteHighlight2.jpg\",\"details\":{\"size\":85482,\"image\":{\"width\":720,\"height\":531}},\"fileName\":\"NavaretteHighlight2.jpg\",\"contentType\":\"image/jpeg\"}}},{\"type\":\"fighterHighlight\",\"id\":\"5Lc6gEo27vv0IlUGj7uufQ\",\"title\":\"Isaac Dogboe II TKO12\",\"bodyCopy\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Navarrete’s first of five title defenses at super bantamweight began with a rematch, and he dropped twice before getting the stoppage victory in the final round.\",\"marks\":[],\"data\":{}}]}]},\"image\":{\"type\":\"Asset\",\"id\":\"4gXSDxzyj0IeghmZ23kNR1\",\"title\":\"NavaretteHighlight3\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/4gXSDxzyj0IeghmZ23kNR1/97f340f00f9b59a31485b3baadf597ef/NavaretteHighlight3.jpg\",\"details\":{\"size\":74515,\"image\":{\"width\":720,\"height\":521}},\"fileName\":\"NavaretteHighlight3.jpg\",\"contentType\":\"image/jpeg\"}}},{\"type\":\"fighterHighlight\",\"id\":\"2NUtQtEj7xi8IkwRMqQIhP\",\"title\":\"Ruben Villa W12\",\"bodyCopy\":{\"nodeType\":\"document\",\"data\":{},\"content\":[{\"nodeType\":\"paragraph\",\"data\":{},\"content\":[{\"nodeType\":\"text\",\"value\":\"Navarrete dropped Villa twice en route to winning the vacant featherweight title by unanimous decision and becoming a two-division champion.\",\"marks\":[],\"data\":{}}]}]},\"image\":{\"type\":\"Asset\",\"id\":\"56X4VJ2jTBA8dAouaG09j\",\"title\":\"NavaretteHighlight4\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/56X4VJ2jTBA8dAouaG09j/ff00e112ff44afacdf26ca69a7769e89/NavaretteHighlight4.jpg\",\"details\":{\"size\":111070,\"image\":{\"width\":1100,\"height\":800}},\"fileName\":\"NavaretteHighlight4.jpg\",\"contentType\":\"image/jpeg\"}}}],\"ringSays\":[{\"type\":\"ringSays\",\"id\":\"7dPbl693MTWXARxiJd1tCK\",\"title\":\"Action over style\",\"isSmallVariant\":true,\"isLargeVariant\":false,\"largeVariationBodyCopy\":null,\"smallVariationBodyCopy\":\"Navarrete doesn't win on boxing X's and O's. He's willing to take a shot to land his.\"},{\"type\":\"ringSays\",\"id\":\"4Hk9cABjPOetIbrUJQckPe\",\"title\":\"Working formula\",\"isSmallVariant\":true,\"isLargeVariant\":false,\"largeVariationBodyCopy\":null,\"smallVariationBodyCopy\":\"He’s awkward, even wild at times, but has won and defended world titles in three divisions.\"},{\"type\":\"ringSays\",\"id\":\"4rSzONkVDs3s58vwjXAaEO\",\"title\":\"Less is more\",\"isSmallVariant\":true,\"isLargeVariant\":false,\"largeVariationBodyCopy\":null,\"smallVariationBodyCopy\":\"Daring to be great, Navarrete moved up to lightweight but Denys Berinchyk outpointed him.\"}],\"compuboxFighterId\":\"6695\"}]},{\"type\":\"ranking\",\"id\":\"66tHynficwuj0C4Gbiz3eA\",\"name\":\"P4P Ranking Women\",\"division\":{\"type\":\"division\",\"id\":\"60MHb4RshrPFOy6Jsxr61W\",\"key\":\"Pound for Pound – Women's\",\"organiz