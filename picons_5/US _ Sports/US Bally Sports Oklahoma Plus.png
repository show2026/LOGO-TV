ighterHighlight\",\"id\":\"4LxmjJzVLEx2up3DuI9GWV\",\"title\":\"Maira Moneo W10\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Drops her opponent and nearly shuts her out to win the vacant WBC \\\"interim\\\" lightweight title. She’s later elevated to full champion.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"1AnLoUjOdGI66zfetcozXX\",\"title\":\"DuboisHighlight3\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/1AnLoUjOdGI66zfetcozXX/926282debce0ecaea1e0072d9e93ae63/DuboisHighlight3.jpg\",\"details\":{\"size\":156111,\"image\":{\"width\":1024,\"height\":683}},\"fileName\":\"DuboisHighlight3.jpg\",\"contentType\":\"image/jpeg\"}}},{\"type\":\"fighterHighlight\",\"id\":\"1Cy8YQUHnVNjWtsr7Fm3iM\",\"title\":\"Magali Rodriguez W10\",\"bodyCopy\":{\"data\":{},\"content\":[{\"data\":{},\"content\":[{\"data\":{},\"marks\":[],\"value\":\"Outboxes her capable veteran opponent to win a clear decision (as well as a minor title) and underscore the perception that she’s a rising young star.\",\"nodeType\":\"text\"}],\"nodeType\":\"paragraph\"}],\"nodeType\":\"document\"},\"image\":{\"type\":\"Asset\",\"id\":\"1rijsYrKhjpO4p4s8wEWYG\",\"title\":\"DuboisHighlight4\",\"description\":\"\",\"file\":{\"url\":\"//images.ctfassets.net/lg76kxmf55ue/1rijsYrKhjpO4p4s8wEWYG/0b3ac55bab5ee60235543a10bed2d464/DuboisHighlight4.jpg\",\"details\":{\"size\":58806,\"image\":{\"width\":768,\"height\":432}},\"fileName\":\"DuboisHighlight4.jpg\",\"contentType\":\"image/jpeg\"}}}],\"compuboxFighterId\":\"8592\"},\"fighterB\":{\"__circularReference\":true,\"id\":\"1KiBMYdo2IyGtqAnky9ITD\",\"type\":\"fighterProfile\"},\"division\":{\"type\":\"division\",\"id\":\"4PA9Zo1j1uieWRKetpPxGg\",\"key\":\"Ring – Junior welterweight – Women\",\"organization\":\"$2:props:children:1:props:children:props:children:props:children:props:children:1:props:childr