    connect-src 'self' https:;
    frame-src 'self' https:;
    worker-src 'self' blob:;
    form-action 'self' https://jobs.ashbyhq.com;
    base-uri 'self';
  ">

  <!-- Security Headers (frame-ancestors and X-Frame-Options must be set via HTTP headers, not meta) -->
