<!doctype html>
<html lang="en" data-beasties-container>
<head>
  <meta charset="utf-8">
  <!-- Critical CSS - loading screen and theme background -->
  <style>
    /* Theme backgrounds */
    html[data-theme="dark"], html[data-theme="dark"] body { background-color: #0f0f0f !important; }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]), html:not([data-theme="light"]) body { background-color: #0f0f0f !important; }
    }

    /* Loading screen */
    #app-loading {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #f8f8f8;
      transition: opacity 0.3s ease-out;
    }
    html[data-theme="dark"] #app-loading { background-color: #0f0f0f; }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) #app-loading { background-color: #0f0f0f; }
    }

    /* Logo visibility based on theme */
    #app-loading .logo-light { display: block; }
    #app-loading .logo-dark { display: none; }
    html[data-theme="dark"] #app-loading .logo-light { display: none; }
    html[data-theme="dark"] #app-loading .logo-dark { display: block; }
    @media (prefers-color-scheme: dark) {
      html:not([data-theme="light"]) #app-loading .logo-light { display: none; }
      html:not([data-theme="light"]) #app-loading .logo-dark { display: block; }
    }

    /* Logo container with shimmer effect */
    #app-loading .logo-container {
      position: relative;
      overflow: hidden;
      display: inline-block;
      animation: logo-scale 2s ease-in-out infinite;
    }
    #app-loading img {
      width: clamp(140px, 22vw, 200px);
      display: block;
    }
    @keyframes logo-scale {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.05); }
    }
    /* Shimmer sweep effect */
    #app-loading .logo-container::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 60%;
      height: 100%;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255, 255, 255, 0.4) 50%,
        transparent 100%
      );
      animation: shimmer 2s ease-in-out infinite;
    }
    html[data-theme="dark"] #app-loading .logo-container::after {
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255, 255, 255, 0.15) 50%,
        transparent 100%
      );
    }
    @keyframes shimmer {
      0% { left: -100%; }
      100% { left: 150%; }
    }

    /* Fade out when ready */
    #app-loading.fade-out {
      opacity: 0;
      pointer-events: none;
    }
  </style>
  <!-- Theme initialization - sets theme attribute before render -->
  <script>
    (function() {
      try {
        var theme = localStorage.getItem('flohome_theme') || 'system';
        var resolved = theme;
        if (theme === 'system') {
          resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', resolved);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
  <!-- Osano Consent Management -->
