<style>
  /* Estilos do Contêiner Principal */
  .player-container {
    position: relative;
    width: 100%;
    /* Relação de aspecto 16:9 */
    padding-bottom: 56.25%; 
    overflow: hidden;
    background-color: black;
  }

  /* Estilos do Iframe (Player) */
  .player-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Estilos Padrão (Desktop) do Overlay */
  #mute-overlay {
    position: absolute;
    top: 15px;
    right: 15px;
    background-color: rgba(0,0,0,0.7);
    color: white;
    padding: 6px 12px;
    border-radius: 14px;
    font-weight: bold;
    font-family: 'roboto condensed', sans-serif;
    cursor: pointer;
    z-index: 10;
    opacity: 0.9;
    transition: opacity 0.5s ease, transform 0.5s ease;
    font-size: 14px;
  }

  /* Estilos de Transição para Mobile */
  @media (max-width: 480px) {
    #mute-overlay {
      top: 10px;
      right: 10px;
      font-size: 12px;
      padding: 4px 8px;
    }
  }

  /* Classe para Esconder o Overlay com a transição */
  .hide-overlay {
    opacity: 0 !important;
    transform: translateY(-20px) !important;
  }
</style>

